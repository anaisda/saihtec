# JWT Secret — CHANGE THIS to a random 64-char string in production
JWT_SECRET=change-this-to-a-very-long-random-secret-string-in-production

# Email via Resend (free: 3000 emails/month) — get key at resend.com
# Leave empty to skip email (messages still saved to admin inbox)
RESEND_API_KEY=

# Node environment
NODE_ENV=production
